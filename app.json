{
  "expo": {
    "name": "DSicarioApp",
    "slug": "dsicario-app",
    "scheme": "dsicario",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },

    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.akuarta.dsicario",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "TU_API_KEY_AQUI"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akuarta.dsicarioapp",
      "config": {
        "googleMapsApiKey": "TU_API_KEY_AQUI"
      }
    },
    "owner": "hairoman28",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear QRs para entregas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2b86deb-3577-44c9-8400-4ec78784f8f9"
      }
    }
  }
}
