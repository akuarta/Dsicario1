{
  "expo": {
    "name": "DSicarioApp",
    "slug": "dsicario-app",
    "scheme": "dsicario",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "vapidPublicKey": "BPvkF9pSNQ4AMYQFycckdxp_YqXP7qwKpkMkve76UEw78WlU7dCFgGJEPi4MtgelEbD4Md7xUANmGPdtzOiEJDE",
      "serviceWorkerPath": "/firebase-messaging-sw.js"
    },
    "jsEngine": "hermes",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.akuarta.dsicario",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBTOwNNoRVgVpDmnGvWOZNCSLbJPCV9mZw"
        }
      },
      "permissions": ["ACCESS_FINE_LOCATION","ACCESS_COARSE_LOCATION"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akuarta.dsicarioapp",
      "config": {
        "googleMapsApiKey": "AIzaSyBTOwNNoRVgVpDmnGvWOZNCSLbJPCV9mZw"
      }
    },
    "owner": "hairoman28",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear QRs para entregas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#A80015",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2b86deb-3577-44c9-8400-4ec78784f8f9"
      }
    }
  }
}
